OPENAI_API_KEY=your_openai_api_key
DATABASE_PATH=./data/app.sqlite
BACKUP_DIR=./data/backups
LOG_LEVEL=info
METRICS_PREFIX=valik
METRICS_API_KEY=
METRICS_IP_ALLOWLIST=

# Optional API security
API_AUTH_KEY=replace_with_strong_api_key
ADMIN_API_KEY=replace_with_strong_admin_key
# Optional: if true, chat and estimate routes are public (for website widget)
PUBLIC_CHAT_ROUTES=false
CORS_ALLOWLIST=https://your-site.com,https://admin.your-site.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=80
SPAM_MAX_MESSAGE_LENGTH=1200
SPAM_MIN_INTERVAL_MS=1200
SPAM_DUPLICATE_WINDOW_MS=15000
SPAM_MAX_DUPLICATE_BURSTS=2
SPAM_MAX_URLS=3
OUTBOX_PROCESS_INTERVAL_MS=15000
OUTBOX_MAX_ATTEMPTS=6
OUTBOX_BACKOFF_BASE_MS=30000
OUTBOX_BACKOFF_MAX_MS=3600000

# Optional CRM integration
CRM_WEBHOOK_URL=
CRM_API_KEY=

# Optional alerting (DLQ notifications)
ALERT_WEBHOOK_URL=
ALERT_API_KEY=
ALERT_SIGNING_SECRET=
ALERT_TIMEOUT_MS=5000

# Optional staging/prod smoke runner
SMOKE_BASE_URL=
SMOKE_API_KEY=
SMOKE_ADMIN_API_KEY=
SMOKE_METRICS_API_KEY=
SMOKE_SEND_TO_CRM=false
SMOKE_STRICT_METRICS=false
SMOKE_START_MESSAGE=Bathroom 6m2, remove old tiles, prime and paint.
SMOKE_FOLLOWUP_MESSAGE=Warsaw, next week, 3 floor, with lift.
